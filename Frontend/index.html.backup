<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Quiz Game</title>
  <link rel="stylesheet" href="/css/style.css" />
  <script src="https://accounts.google.com/gsi/client" async defer></script>
</head>
<body>

  <!-- NAVBAR -->
  <nav class="navbar">
    <div class="logo" onclick="showPage('page-home')">QuizGame I.T Question</div>
    <div class="nav-right">
      <div id="user-info" class="hidden">
        <img id="user-avatar" src="" alt="avatar" />
        <span id="user-name"></span>
        <button onclick="logout()" class="btn btn-outline">Logout</button>
      </div>
      <div id="login-btn">
        <div id="g_id_onload"
          data-client_id="124519552375-roffvrv4lmrpk4jkcr8951j57pa776h0.apps.googleusercontent.com"
          data-callback="handleCredentialResponse">
        </div>
        <div class="g_id_signin" data-type="standard"></div>
      </div>
    </div>
  </nav>

  <!-- HOME PAGE -->
  <div id="page-home" class="page">
    <div class="hero">
      <h1>Welcome to <span>QuizGame</span></h1>
      <p>Test your knowledge,go in top and climb in Leaderboard</p>
      <div class="hero-btns">
        <button onclick="showPage('page-quizlist')" class="btn btn-primary">Quizzes</button>
        <button onclick="showPage('page-leaderboard')" class="btn btn-outline">Leaderboard</button>
      </div>
    </div>
  </div>

  <!-- QUIZ LIST PAGE -->
  <div id="page-quizlist" class="page hidden">
    <div class="container">
      <h2>Available Quizzes</h2>
      <div id="quiz-list" class="quiz-grid"></div>
      <button onclick="showPage('page-home')" class="btn btn-outline mt">← Back</button>
    </div>
  </div>

  <!-- QUIZ PLAY PAGE -->
  <div id="page-quiz" class="page hidden">
    <div class="container">
      <div class="quiz-header">
        <h2 id="quiz-title"></h2>
        <span class="quiz-progress">Question <span id="current-q">1</span> of <span id="total-q">0</span></span>
      </div>
      <div class="progress-bar">
        <div id="progress-fill" class="progress-fill"></div>
      </div>
      <div class="question-box">
        <p id="question-text"></p>
        <div id="options-list" class="options-list"></div>
      </div>
      <button id="next-btn" class="btn btn-primary hidden" onclick="nextQuestion()">Next</button>
    </div>
  </div>

  <!-- RESULT PAGE -->
  <div id="page-result" class="page hidden">
    <div class="container result-box">
      <div id="result-emoji" class="result-emoji"></div>
      <h2>Quiz Complete!</h2>
      <div class="score-display">
        <span id="result-score"></span>
        <span class="score-label">Score</span>
      </div>
      <p id="result-msg"></p>
      <div id="result-details" class="result-details"></div>
      <div class="result-actions">
        <button onclick="showPage('page-quizlist')" class="btn btn-primary">Play Again</button>
        <button onclick="showPage('page-leaderboard')" class="btn btn-outline">Leaderboard</button>
      </div>
    </div>
  </div>

  <!-- LEADERBOARD PAGE -->
  <div id="page-leaderboard" class="page hidden">
    <div class="container">
      <h2> Leaderboard</h2>
      <div id="leaderboard-list" class="leaderboard-list"></div>
      <button onclick="showPage('page-home')" class="btn btn-outline mt">← Back</button>
    </div>
  </div>

  <script src="/js/main.js"></script>
</body>
</html>